# ── Anthropic API (answers) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Bare model id (no provider prefix). Haiku 4.5 is cheap; switch to claude-opus-4-8 for top quality.
ANTHROPIC_MODEL=claude-haiku-4-5
MAX_TOKENS=1024

# ── Local embeddings (no key needed) ─────────────────────────────────────────
EMBED_MODEL=BAAI/bge-small-en-v1.5
INDEX_FILE=rag_index.pkl

# ── Retrieval ────────────────────────────────────────────────────────────────
TOP_K=5
MIN_SIMILARITY=0.3
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# ── CORS (the site origins allowed to call this API) ─────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Abuse / cost guards on /chat (per client IP)
RATE_LIMIT_PER_MINUTE=12
RATE_LIMIT_PER_DAY=300
MAX_QUERY_CHARS=500
